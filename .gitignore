# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
venv/
.venv/
env/
.env/

# Local environment and secrets
.env
.env.*
*.local
wandb/

# Jupyter
.ipynb_checkpoints/

#Doc
docs/

# Training outputs (Syncthing handles these between machines)
results/
checkpoints/
runs/
outputs/
training_logs/
*.pt
*.pth
*.ckpt
*.onnx

# Syncthing startup scripts (machine-specific, paths differ per PC)
scripts/start_syncthing.*
scripts\run_ptbxl_full.ps1*
# Local datasets and downloaded archives
data/ESC-50/
data/ptbxl/
data/*.zip
data/*.tar
data/*.tar.gz
data/*.tgz
data/*.h5
data/*.hdf5

# Generated figures, logs, and metrics
*.log
*.csv
*.png
*.jpg
*.jpeg
*.pdf
*.sh

# Keep source configs and notebooks trackable despite broad generated-output ignores
!configs/*.yaml
!notebooks/*.ipynb

# Local tools and large binaries
tools/ffmpeg/

# OS and editor files
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Project assistant/local metadata
.claude/
